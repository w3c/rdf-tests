  "@id": "manifest-direct.ttl",
  "@type": "mf:Manifest",
  "label": "SPARQL Graph Store Protocol - Direct Graph Identification",
  "entries": [
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/http-rdf-update/manifest#put_get_repeat_direct",
      "@type": "mf:GraphStoreProtocolTest",
      "name": "PUT/GET repetition on same graph using varying graph identification  (direct graph identification)",
      "requires": [
        "mf:DirectGraphIdentification"
      ],
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                        @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                        @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                        <http://www.example/gsp/person/1> a foaf:Person;\n                            foaf:businessCard [\n                                a v:VCard;\n                                v:fn \"John Doe\"\n                            ].\n                    "
              },
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#methodName": "PUT",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#Created"
                }
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
                  "@type": "http://www.w3.org/2011/content#ContentAsText",
                  "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                  "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                               foaf:businessCard [\n                                    a v:VCard;\n                                    v:fn \"John Doe\"\n                               ].\n                        "
                }
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "PUT",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                        @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                        @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                    \n                        <http://www.example/gsp/person/1> a foaf:Person;\n                            foaf:businessCard [\n                                a v:VCard;\n                                v:fn \"Jane Doe\"\n                            ].\n                    "
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
                  "@type": "http://www.w3.org/2011/content#ContentAsText",
                  "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                  "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                               foaf:businessCard [\n                                    a v:VCard;\n                                    v:fn \"Jane Doe\"\n                               ] .\n                        "
                }
              }
            }
          ]
        }
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/http-rdf-update/manifest#put_delete_get_delete_direct",
      "@type": "mf:GraphStoreProtocolTest",
      "name": "PUT initialization, then DELETE/GET/DELETE (direct graph identification)",
      "requires": [
        "mf:DirectGraphIdentification"
      ],
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "PUT",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                        @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                        @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                    \n                        []  a foaf:Person;\n                            foaf:businessCard [\n                                a v:VCard;\n                                v:given-name \"Alice\"\n                            ] .\n                    "
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#Created"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "DELETE",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#NotFound"
                }
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "DELETE",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NotFound"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            }
          ]
        }
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/http-rdf-update/manifest#post_get_post_get_direct",
      "@type": "mf:GraphStoreProtocolTest",
      "name": "Two iterations os POST/GET, with the second using multipart/form-data (direct graph identification)",
      "requires": [
        "mf:DirectGraphIdentification"
      ],
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                               foaf:businessCard [\n                                    a v:VCard;\n                                    v:fn \"Jane Doe\"\n                               ] .\n                    "
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#Created"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
                  "@type": "http://www.w3.org/2011/content#ContentAsText",
                  "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                  "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                               foaf:businessCard [\n                                    a v:VCard;\n                                    v:fn \"Jane Doe\"\n                               ] .\n                        "
                }
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "--a6fe4cd636164618814be9f8d3d1a0de\r\nContent-Disposition: form-data; name=\"lastName.ttl\"; filename=\"lastName.ttl\"\r\nContent-Type: text/turtle; charset=utf-8\r\n\r\n@prefix foaf: <http://xmlns.com/foaf/0.1/> .\r\n<http://www.example/gsp/person/1> foaf:familyName \"Doe\" .\r\n\r\n--a6fe4cd636164618814be9f8d3d1a0de\r\nContent-Disposition: form-data; name=\"firstName.ttl\"; filename=\"firstName.ttl\"\r\nContent-Type: text/turtle; charset=utf-8\r\n\r\n@prefix foaf: <http://xmlns.com/foaf/0.1/> .\r\n<http://www.example/gsp/person/1> foaf:givenName \"Jane\" .\r\n\r\n--a6fe4cd636164618814be9f8d3d1a0de--\r\n"
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "multipart/form-data; boundary=a6fe4cd636164618814be9f8d3d1a0de"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
                  "@type": "http://www.w3.org/2011/content#ContentAsText",
                  "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                  "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                                foaf:givenName      \"Jane\";\n                                foaf:familyName     \"Doe\";\n                                foaf:businessCard [\n                                    a               v:VCard;\n                                    v:fn            \"Jane Doe\"\n                                ] .\n                        "
                }
              }
            }
          ]
        }
      }
    },
    {
