  "@id": "./",
  "@type": "mf:Manifest",
  "label": "SPARQL Graph Store Protocol",
  "comment": "\n        This manifest encodes tests for the SPARQL Graph Store Protocol.\n        Each test record has one or more ht:Requests that must be run in order\n        to produce the expected results.\n        \n        Expected results are encoded in the ht:Response. The ht:Response may\n        have a `mf:expectedStatus` property, describing the expected HTTP\n        status code or class of status code (pointing to values\n        like `hts:Created` or `hts:StatusCode2xx`);\n        \n        The ht:Response may have a `mf:expectedLocation` property whose value\n        is a literal. In the presence of this property, the current response\n        must have a `Location` header field value. Futher, the literal value\n        must be used as a template variable and replaced in subsequent requests\n        with the header field value (replacement occurring in the request URI\n        as well as the request bodies).\n        \n        The ht:Response may include expected RDF response content, described\n        by `ht:headers` and `ht:body`. When present, the graph resulting from\n        parsing the ht:body content appropriately for the RDF format described\n        by the Content-Type header must be graph isomorphic to the one in the\n        response to the Graph Store Protocol request.\n\n        Each request has a ht:absolutePath value that starts with `/gsp`.\n        A program using this manifest data to run the tests must replace this\n        value with whatever path prefix is appropriate for the Graph Store\n        Protocol endpoint being tested.\n    ",
  "entries": [
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/http-rdf-update/manifest#put_get_repeat",
      "@type": "mf:GraphStoreProtocolTest",
      "name": "PUT/GET repetition on same graph using varying graph identification",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                        @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                        @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                        <http://www.example/gsp/person/1> a foaf:Person;\n                            foaf:businessCard [\n                                a v:VCard;\n                                v:fn \"John Doe\"\n                            ].\n                    "
              },
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#methodName": "PUT",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#Created"
                }
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp?graph=http://www.example/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
                  "@type": "http://www.w3.org/2011/content#ContentAsText",
                  "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                  "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                               foaf:businessCard [\n                                    a v:VCard;\n                                    v:fn \"John Doe\"\n                               ].\n                        "
                }
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "PUT",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp?graph=http://www.example/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                        @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                        @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                    \n                        <http://www.example/gsp/person/1> a foaf:Person;\n                            foaf:businessCard [\n                                a v:VCard;\n                                v:fn \"Jane Doe\"\n                            ].\n                    "
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
                  "@type": "http://www.w3.org/2011/content#ContentAsText",
                  "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                  "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                               foaf:businessCard [\n                                    a v:VCard;\n                                    v:fn \"Jane Doe\"\n                               ] .\n                        "
                }
              }
            }
          ]
        }
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/http-rdf-update/manifest#put_get_default",
      "@type": "mf:GraphStoreProtocolTest",
      "name": "PUT/GET on the default graph",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "PUT",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp?default",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                        @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                        @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                    \n                        []  a foaf:Person;\n                            foaf:businessCard [\n                                a v:VCard;\n                                v:given-name \"Alice\"\n                            ] .\n                    "
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp?default",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
                  "@type": "http://www.w3.org/2011/content#ContentAsText",
                  "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                  "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            []  a foaf:Person;\n                                foaf:businessCard [\n                                    a v:VCard;\n                                    v:given-name \"Alice\"\n                                ] .\n                        "
                }
              }
            }
          ]
        }
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/http-rdf-update/manifest#put_delete_get_delete",
      "@type": "mf:GraphStoreProtocolTest",
      "name": "PUT initialization, then DELETE/GET/DELETE on a direct-identified graph",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "PUT",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                        @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                        @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                    \n                        []  a foaf:Person;\n                            foaf:businessCard [\n                                a v:VCard;\n                                v:given-name \"Alice\"\n                            ] .\n                    "
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#Created"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "DELETE",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#NotFound"
                }
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "DELETE",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/2.ttl",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NotFound"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            }
          ]
        }
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/http-rdf-update/manifest#post_get_post_get",
      "@type": "mf:GraphStoreProtocolTest",
      "name": "Two iterations os POST/GET, with the second using multipart/form-data",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "\n                            @prefix foaf: <http://xmlns.com/foaf/0.1/> .\n                            @prefix v: <http://www.w3.org/2006/vcard/ns#> .\n                        \n                            <http://www.example/gsp/person/1> a foaf:Person;\n                               foaf:businessCard [\n                                    a v:VCard;\n                                    v:fn \"Jane Doe\"\n                               ] .\n                    "
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http-statusCodes#NoContent"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#methodName": "GET",
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#absolutePath": "/gsp/person/1.ttl",
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "accept",
                    "http://www.w3.org/2011/http#fieldValue": "text/turtle"
                  }
                ]
              },
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http-statusCodes#OK"
                },
                "http://www.w3.org/2011/http#headers": {
                  "@list": [
                    {
                      "@type": "http://www.w3.org/2011/http#ResponseHeader",
                      "http://www.w3.org/2011/http#fieldName": "content-type",
                      "http://www.w3.org/2011/http#fieldValue": "text/turtle; charset=utf-8"
                    }
                  ]
                },
                "http://www.w3.org/2011/http#body": {
