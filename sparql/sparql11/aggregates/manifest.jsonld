      "@type": "mf:QueryEvaluationTest",
      "name": "agg on empty set, no grouping",
      "comment": "aggregating empty results with no group-by always returns a single result.",
      "feature": "http://www.w3.org/ns/sparql#aggregate",
      "action": {
        "query": "agg-empty-group-max-2.rq",
