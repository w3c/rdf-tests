:update_base_uri rdf:type mf:ProtocolTest ;
        rdfs:comment "Tests REQ-5.1.1" ;
        rdfs:comment "Rec §2.4" ;
        ut:graphData [ ut:graph <data1.nt> ; rdfs:label "http://kasei.us/2009/09/sparql/data/data1.rdf" ] ;
        mf:name    "test that service-defined BASE URI resolves relative IRIs in updates" ;
        mf:action [
            a ht:Connection ;
            ht:connectionAuthority "www.example" ;
            ht:requests ([
                    a ht:Request ;
                    ht:absolutePath "/sparql/" ;
                    ht:body [
                        a cnt:ContentAsText ;
                        cnt:characterEncoding "UTF-8" ;
                        cnt:chars """CLEAR SILENT GRAPH <http://example.org/protocol-base-test/> ;
INSERT DATA { GRAPH <http://example.org/protocol-base-test/> { <http://example.org/s> <http://example.org/p> <test> } }"""
                    ] ;
                    ht:headers ([
                            a ht:RequestHeader ;
                            ht:fieldName "content-type" ;
                            ht:fieldValue "application/sparql-update"
                        ]
                    ) ;
                    ht:httpVersion "1.1" ;
                    ht:methodName "POST" ;
                    ht:resp [
                        a ht:Response ;
                        mf:expectedStatus ht:StatusCode2xx, ht:StatusCode3xx
                    ]
                ]
                [
                    a ht:Request ;
                    ht:absolutePath "/sparql/" ;
                    ht:body [
                        a cnt:ContentAsText ;
                        cnt:characterEncoding "UTF-8" ;
                        cnt:chars """ASK {
  GRAPH <http://example.org/protocol-base-test/> {
    <http://example.org/s> <http://example.org/p> ?o
    FILTER (isIRI(?o) && ?o != <test>)
  }
}"""
                    ] ;
                    ht:headers ([
                            a ht:RequestHeader ;
                            ht:fieldName "content-type" ;
                            ht:fieldValue "application/sparql-query"
                        ]
                    ) ;
                    ht:httpVersion "1.1" ;
                    ht:methodName "POST" ;
                    ht:resp [
                        a ht:Response ;
                        mf:expectedBoolean true ;
                        mf:expectedFormat "boolean" ;
                        mf:expectedStatus ht:StatusCode2xx, ht:StatusCode3xx
                    ]
                ]
            )
        ] ;
        rdfs:comment """
The update inserts a triple with the relative IRI `<test>` as object.
The service must resolve this against its base URI (per RFC 3986 §5.1.4),
so the stored object will be an absolute IRI — not the literal `<test>`.
The verification ASK query checks that the object is an IRI that differs
from the unresolved relative form `<test>`.

#### Request 1 (update)

    POST /sparql/ HTTP/1.1
    Host: www.example
    Content-Type: application/sparql-update

    CLEAR SILENT GRAPH <http://example.org/protocol-base-test/> ;
    INSERT DATA { GRAPH <http://example.org/protocol-base-test/> {
        <http://example.org/s> <http://example.org/p> <test>
    } }

#### Response 1

    2xx or 3xx

#### Request 2 (verify)

    POST /sparql/ HTTP/1.1
    Host: www.example
    Content-Type: application/sparql-query

    ASK {
      GRAPH <http://example.org/protocol-base-test/> {
        <http://example.org/s> <http://example.org/p> ?o
        FILTER (isIRI(?o) && ?o != <test>)
      }
    }

#### Response 2

    2xx or 3xx — true
        """ ;
  dawgt:approval dawgt:NotClassified;
        .

