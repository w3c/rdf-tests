:query_base_uri rdf:type mf:ProtocolTest ;
        rdfs:comment "Tests REQ-5.1.1" ;
        rdfs:comment "Rec §2.4" ;
        ut:graphData [ ut:graph <data1.nt> ; rdfs:label "http://kasei.us/2009/09/sparql/data/data1.rdf" ] ;
        mf:name "test that BASE keyword in query resolves relative IRIs" ;
        mf:action [
            a ht:Connection ;
            ht:connectionAuthority "www.example" ;
            ht:requests ([
                    a ht:Request ;
                    ht:absolutePath "/sparql/" ;
                    ht:body [
                        a cnt:ContentAsText ;
                        cnt:characterEncoding "UTF-8" ;
                        cnt:chars """CLEAR SILENT GRAPH <http://example.org/protocol-base-query-test/> ;
INSERT DATA { GRAPH <http://example.org/protocol-base-query-test/> { <http://example.org/s> <http://example.org/p> <http://example.org/o> } }"""
                    ] ;
                    ht:headers ([
                            a ht:RequestHeader ;
                            ht:fieldName "content-type" ;
                            ht:fieldValue "application/sparql-update"
                        ]
                    ) ;
                    ht:httpVersion "1.1" ;
                    ht:methodName "POST" ;
                    ht:resp [
                        a ht:Response ;
                        mf:expectedStatus ht:StatusCode2xx, ht:StatusCode3xx
                    ]
                ]
                [
                    a ht:Request ;
                    ht:absolutePath "/sparql/" ;
                    ht:body [
                        a cnt:ContentAsText ;
                        cnt:characterEncoding "UTF-8" ;
                        cnt:chars """BASE <http://example.org/>
ASK {
  GRAPH <protocol-base-query-test/> {
    <s> <p> <o>
  }
}"""
                    ] ;
                    ht:headers ([
                            a ht:RequestHeader ;
                            ht:fieldName "content-type" ;
                            ht:fieldValue "application/sparql-query"
                        ]
                    ) ;
                    ht:httpVersion "1.1" ;
                    ht:methodName "POST" ;
                    ht:resp [
                        a ht:Response ;
                        mf:expectedBoolean true ;
                        mf:expectedFormat "boolean" ;
                        mf:expectedStatus ht:StatusCode2xx, ht:StatusCode3xx
                    ]
                ]
            )
        ] ;
        rdfs:comment """
The update inserts a triple with absolute IRIs into a named graph.
The verification ASK query uses BASE to declare a base IRI, then
refers to the graph and triple components using relative IRIs.
If BASE resolution works correctly, the relative IRIs resolve to
the same absolute IRIs used in the INSERT DATA, and the ASK returns true.

#### Request 1 (update)

    POST /sparql/ HTTP/1.1
    Host: www.example
    Content-Type: application/sparql-update

    CLEAR SILENT GRAPH <http://example.org/protocol-base-query-test/> ;
    INSERT DATA { GRAPH <http://example.org/protocol-base-query-test/> {
        <http://example.org/s> <http://example.org/p> <http://example.org/o>
    } }

#### Response 1

    2xx or 3xx

#### Request 2 (verify)

    POST /sparql/ HTTP/1.1
    Host: www.example
    Content-Type: application/sparql-query

    BASE <http://example.org/>
    ASK {
      GRAPH <protocol-base-query-test/> {
        <s> <p> <o>
      }
    }

#### Response 2

    2xx or 3xx — true
        """;
        dawgt:approval dawgt:NotClassified ;
  .


:query_content_negotiation_json rdf:type mf:ProtocolTest ;
        rdfs:comment "Tests REQ-3.6.1" ;
        rdfs:comment "Rec §2.2.5, §2.2.6" ;
  ut:graphData [ ut:graph <data1.nt> ; rdfs:label "http://kasei.us/2009/09/sparql/data/data1.rdf" ] ;
  mf:action [
    a ht:Connection;
    ht:connectionAuthority "www.example";
    ht:requests ([
        a ht:Request;
        ht:absolutePath "/sparql";
        ht:body [
          a cnt:ContentAsText;
          cnt:characterEncoding "UTF-8";
          cnt:chars "query=ASK%20%7B%7D&default-graph-uri=http%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata1.rdf"
        ];
        ht:headers ([
            a ht:RequestHeader;
            ht:fieldName "Content-Type";
            ht:fieldValue "application/x-www-form-urlencoded";
            ht:headerElements ([
                a ht:HeaderElement;
                ht:elementName "application/x-www-form-urlencoded"
              ])
          ] [
            a ht:RequestHeader;
            ht:fieldName "Accept";
            ht:fieldValue "application/sparql-results+json";
            ht:headerElements ([
                a ht:HeaderElement;
                ht:elementName "application/sparql-results+json"
              ])
          ]);
        ht:httpVersion "1.1";
        ht:methodName "POST";
        ht:resp [
          a ht:Response;
          ht:headers ([
              a ht:RequestHeader;
              ht:fieldName "Content-Type";
              ht:fieldValue "application/sparql-results+json";
              ht:headerElements ([
                  a ht:HeaderElement;
                  ht:elementName "application/sparql-results+json"
                ])
            ]);
          ht:statusCodeValue "2XX",
            "3XX"
        ]
      ])
  ];
  mf:name "query requesting specific format via Accept header (JSON)";
  dawgt:approval dawgt:NotClassified;
        .

