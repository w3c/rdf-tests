@prefix :       <http://www.w3.org/2009/sparql/docs/tests/data-sparql11/protocol/manifest#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mf:     <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix qt:     <http://www.w3.org/2001/sw/DataAccess/tests/test-query#> .
@prefix dawgt:  <http://www.w3.org/2001/sw/DataAccess/tests/test-dawg#> .
@prefix cnt:    <http://www.w3.org/2011/content#> .
@prefix ht:     <http://www.w3.org/2011/http#> .
@prefix sd:     <http://www.w3.org/ns/sparql-service-description#> .
@prefix ut:     <http://www.w3.org/2009/sparql/tests/test-update#> .

<>  rdf:type mf:Manifest ;
    rdfs:label "SPARQL 1.1 Protocol" ;
    rdfs:comment """
        This manifest contains the SPARQL 1.1 Protocol tests, as inherited
        by SPARQL 1.2. A conformant SPARQL 1.2 service must satisfy both
        this manifest and the sibling SPARQL 1.2-specific manifest at
        `../../sparql12/protocol/manifest.ttl` (which adds tests for the
        `version` announcement mechanism introduced in SPARQL 1.2).

        Each test record has one or more `ht:Requests` that must be run in
        order to produce the expected results. Expected results are
        encoded in the `ht:Response` using:

        * `mf:expectedStatus` - Expected HTTP status code (pointing to
          values like `ht:StatusCode2xx`);
        * `ht:statusCodeValue` - Expected status pattern ("2XX","3XX","4XX");
        * `mf:expectedBoolean` - Expected results for ASK queries;
        * `mf:expectedFormat` - Expected serialization format of the
          results; one of the literals "boolean", "tabular", or "RDF";
        * `mf:expectation` - A textual description of the expected
          results where modeling the expectation would have been
          prohibitive (legacy form, retained on one test).

        Each request's `ht:absolutePath` value starts with `/sparql`.
        A program using this manifest must replace this prefix with
        whatever path is appropriate for the endpoint being tested.
        An endpoint being tested may require different endpoints to be
        used for Query and Update requests.

        Each test has an `rdfs:comment` of the form `"Tests REQ-…"`
        linking it to the SPARQL 1.1 Protocol Requirements document
        in this directory (`requirements.md`). For the 1.2-specific
        additions and their tests, see
        `../../sparql12/protocol/requirements.md` and
        `../../sparql12/protocol/manifest.ttl`.
    """ ;
    mf:entries
    (
        :bad_multiple_queries
        :bad_multiple_queries_form
        :bad_multiple_updates
        :bad_query_get_with_body
        :bad_query_method
        :bad_query_missing_direct_type
        :bad_query_missing_form_type
        :bad_query_non_utf8
        :bad_query_syntax
        :bad_query_wrong_media_type
        :bad_update_dataset_conflict
        :bad_update_form_body_missing
        :bad_update_get
        :bad_update_missing_form_type
        :bad_update_non_utf8
        :bad_update_syntax
        :bad_update_wrong_media_type
        :query_base_uri
        :query_content_negotiation_json
        :query_content_negotiation_xml
        :query_content_type_ask
        :query_content_type_construct
        :query_content_type_describe
        :query_content_type_select
        :query_dataset_default_graph
        :query_dataset_default_graphs_get
        :query_dataset_default_graphs_post
        :query_dataset_full
        :query_dataset_named_graphs_get
        :query_dataset_named_graphs_post
        :query_get
        :query_multiple_dataset
        :query_post_direct
        :query_post_form
        :query_post_form_dataset
        :update_base_uri
        :update_dataset_default_graph
        :update_dataset_default_graphs
        :update_dataset_full
        :update_dataset_named_graphs
        :update_post_direct
        :update_post_form
    ) .

:query_post_form rdf:type mf:ProtocolTest ;
        rdfs:comment "Tests REQ-3.3.1, REQ-3.3.5" ;
        rdfs:comment "Rec §2.2.2" ;
        ut:graphData [ ut:graph <data1.nt> ; rdfs:label "http://kasei.us/2009/09/sparql/data/data1.rdf" ] ;
        mf:name    "query via URL-encoded POST" ;
        mf:action [
            a ht:Connection ;
            ht:connectionAuthority "www.example" ;
            ht:requests ([
                    a ht:Request ;
                    ht:absolutePath "/sparql/?default-graph-uri=http%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata1.rdf" ;
                    ht:body [
                        a cnt:ContentAsText ;
                        cnt:characterEncoding "UTF-8" ;
                        cnt:chars "query=ASK%20%7B%7D"
                    ] ;
                    ht:headers ([
                            a ht:RequestHeader ;
                            ht:fieldName "content-type" ;
                            ht:fieldValue "application/x-www-form-urlencoded"
                        ]
                    ) ;
                    ht:httpVersion "1.1" ;
                    ht:methodName "POST" ;
                    ht:resp [
                        a ht:Response ;
                        mf:expectedBoolean true ;
                        mf:expectedFormat "boolean" ;
                        mf:expectedStatus ht:StatusCode2xx, ht:StatusCode3xx
                    ]
                ]
            )
        ] ;
        rdfs:comment """
#### Request
    
    POST /sparql/?default-graph-uri=http%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata1.rdf HTTP/1.1
    Host: www.example
    Content-Type: application/x-www-form-urlencoded
    Content-Length: 18
    
    query=ASK%20%7B%7D

#### Response
    
    2xx or 3xx response
    Content-Type: application/sparql-results+xml, application/sparql-results+json, or any other valid media type for boolean SPARQL results
        
    true
        """ ;
  dawgt:approval dawgt:NotClassified;
        .

:query_post_form_dataset rdf:type mf:ProtocolTest ;
        rdfs:comment "Tests REQ-3.3.2, REQ-3.5.1" ;
        rdfs:comment "Rec §2.2.2, §2.2.4" ;
        ut:graphData [ ut:graph <data1.nt> ; rdfs:label "http://kasei.us/2009/09/sparql/data/data1.rdf" ] ;
        mf:name "query via URL-encoded POST with dataset in request body" ;
        mf:action [
            a ht:Connection ;
            ht:connectionAuthority "www.example" ;
            ht:requests ([
                    a ht:Request ;
                    ht:absolutePath "/sparql/" ;
                    ht:body [
                        a cnt:ContentAsText ;
                        cnt:characterEncoding "UTF-8" ;
                        cnt:chars "query=ASK%20%7B%20%3Chttp%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata1.rdf%3E%20%3Fp%20%3Fo%20%7D&default-graph-uri=http%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata1.rdf"
                    ] ;
                    ht:headers ([
                            a ht:RequestHeader ;
                            ht:fieldName "content-type" ;
                            ht:fieldValue "application/x-www-form-urlencoded"
                        ]
                    ) ;
                    ht:httpVersion "1.1" ;
                    ht:methodName "POST" ;
                    ht:resp [
                        a ht:Response ;
                        mf:expectedBoolean true ;
                        mf:expectedFormat "boolean" ;
                        mf:expectedStatus ht:StatusCode2xx, ht:StatusCode3xx
                    ]
                ]
            )
        ] ;
        rdfs:comment """
All parameters including the dataset specification are in the
URL-encoded request body, per Rec §2.2.2.

#### Request

    POST /sparql/ HTTP/1.1
    Host: www.example
    Content-Type: application/x-www-form-urlencoded

    query=ASK%20%7B%20%3Chttp%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata1.rdf%3E%20%3Fp%20%3Fo%20%7D&default-graph-uri=http%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata1.rdf

#### Response

    2xx or 3xx — true
        """ ;
        dawgt:approval dawgt:NotClassified ;
        .

