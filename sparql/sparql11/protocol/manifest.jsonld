    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/protocol/manifest#update_base_uri",
      "@type": "mf:ProtocolTest",
      "name": "test for service-defined BASE URI (\"which MAY be the service endpoint\")",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#absolutePath": "/sparql/",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "CLEAR SILENT GRAPH <http://example.org/protocol-base-test/> ;\nINSERT DATA { GRAPH <http://example.org/protocol-base-test/> { <http://example.org/s> <http://example.org/p> <test> } }"
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "application/sparql-update"
                  }
                ]
              },
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode2xx"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode3xx"
                  }
                ]
              }
            },
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#absolutePath": "/sparql/",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "SELECT ?o WHERE {\n    GRAPH <http://example.org/protocol-base-test/> {\n        <http://example.org/s> <http://example.org/p> ?o\n    }\n}"
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "application/sparql-query"
                  }
                ]
              },
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectation": "one result with `?o` bound to an IRI that is _not_ `<test>`",
                "mf:expectedFormat": "tabular",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode2xx"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode3xx"
                  }
                ]
              }
            }
          ]
        }
      },
      "comment": "\n#### Request\n    \n    POST /sparql/ HTTP/1.1\n    Host: www.example\n    Content-Type: application/sparql-update\n    Content-Length: 174\n\n    CLEAR GRAPH <http://example.org/protocol-base-test/> ;\n    INSERT DATA { GRAPH <http://example.org/protocol-base-test/> { <http://example.org/s> <http://example.org/p> <test> } }\n    \n#### Response\n    \n    2xx or 3xx response\n\nfollowed by\n\n#### Request\n    \n    POST /sparql/ HTTP/1.1\n    Host: www.example\n    Content-Type: application/sparql-query\n    Content-Length: 123\n\n    SELECT ?o WHERE {\n        GRAPH <http://example.org/protocol-base-test/> {\n            <http://example.org/s> <http://example.org/p> ?o\n        }\n    }\n\n#### Response\n    \n    2xx or 3xx response\n    Content-Type: application/sparql-results+xml, application/sparql-results+json, or any other valid media type for tabular SPARQL results\n    \n    one result with `?o` bound to an IRI that is _not_ `<test>`\n        ",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-11-20#resolution_3"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/protocol/manifest#query_post_direct",
      "@type": "mf:ProtocolTest",
      "name": "query via POST directly",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#absolutePath": "/sparql/",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "ASK {}"
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "application/sparql-query"
                  }
                ]
              },
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedBoolean": {
                  "@type": "xsd:boolean",
                  "@value": "true"
                },
                "mf:expectedFormat": "boolean",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode2xx"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode3xx"
                  }
                ]
              }
            }
          ]
        }
      },
      "comment": "\n#### Request\n    \n    POST /sparql/ HTTP/1.1\n    Host: www.example\n    Content-Length: 6\n    Content-Type: application/sparql-query\n    \n    ASK {}\n    \n#### Response\n    \n    2xx or 3xx response\n    Content-Type: application/sparql-results+xml, application/sparql-results+json, or any other valid media type for boolean SPARQL results\n    \n    true\n        ",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-11-20#resolution_3"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/protocol/manifest#bad_query_method",
