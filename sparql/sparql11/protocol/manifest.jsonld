    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/protocol/manifest#bad_update_dataset_conflict",
      "@type": "mf:ProtocolTest",
      "name": "invoke update with both using-graph-uri/using-named-graph-uri parameter and USING/WITH clause",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#absolutePath": "/sparql/?using-named-graph-uri=http%3A%2F%2Fexample%2Fpeople",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "PREFIX foaf:  <http://xmlns.com/foaf/0.1/>\nWITH <http://example/addresses>\nDELETE { ?person foaf:givenName 'Bill' }\nINSERT { ?person foaf:givenName 'William' }\nWHERE {\n    ?person foaf:givenName 'Bill'\n}"
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "application/sparql-update"
                  }
                ]
              },
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedStatus": {
                  "@id": "http://www.w3.org/2011/http#StatusCode4xx"
                }
              }
            }
          ]
        }
      },
      "comment": "\n#### Request\n    \n    POST /sparql/?using-named-graph-uri=http%3A%2F%2Fexample%2Fpeople HTTP/1.1\n    Host: www.example\n    Content-Type: application/sparql-update\n    Content-Length: 203\n\n    PREFIX foaf:  <http://xmlns.com/foaf/0.1/>\n    WITH <http://example/addresses>\n    DELETE { ?person foaf:givenName 'Bill' }\n    INSERT { ?person foaf:givenName 'William' }\n    WHERE {\n        ?person foaf:givenName 'Bill'\n    }\n\n#### Response\n    \n    4xx\n        ",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-11-20#resolution_3"
    }
  ]
