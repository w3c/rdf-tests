          ]
        }
      },
      "comment": "\n#### Request\n    \n    POST /sparql/ HTTP/1.1\n    Host: www.example\n    Content-Length: 16\n    Content-Type: application/x-www-form-urlencoded\n    \n    update=CLEAR+ALL\n    \n#### Response\n    \n    2xx or 3xx response\n        ",
      "approval": "dawgt:Approved",
