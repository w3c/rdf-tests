  "@id": "./",
  "@type": "mf:Manifest",
  "label": "SPARQL Protocol",
  "comment": "\n    \tThis manifest encodes tests for the SPARQL Protocol. Each test record\n    \thas one or more ht:Requests that must be run in order to produce the\n    \texpected results.\n    \t\n    \tExpected results are encoded in the ht:Response using one of four new\n    \tterms:\n    \t\n    \t* `mf:expectedStatus` - Expected HTTP status code (pointing to values\n    \t      like `ht:StatusCode2xx`);\n    \t* `mf:expectedBoolean` - Expected results for ASK queries.\n    \t* `mf:expectedFormat` - Expected serialization format of the results;\n    \t      the range here is one of the literals: `\"boolean\"`, `\"tabular\"`,\n    \t      or `\"RDF\"`\n    \t* `mf:expectation` - A textual description of the expected results for\n    \t      the single test `update_base_uri` where modeling the expectation\n    \t      would have been prohibitive.\n\n    \tEach request has a ht:absolutePath value that starts with `/sparql/`.\n    \tA program using this manifest data to run the tests must replace this\n    \tvalue with whatever path prefix is appropriate for the endpoint being\n    \ttested. Every ht:absolutePath value in this manifest starts with\n    \t`/sparql/`, but and endpoint being tested may require different\n    \tendpoints to be used for Query and Update requests.\n    ",
  "entries": [
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/protocol/manifest#query_post_form",
      "@type": "mf:ProtocolTest",
      "name": "query via URL-encoded POST",
      "action": {
        "@type": "http://www.w3.org/2011/http#Connection",
        "http://www.w3.org/2011/http#connectionAuthority": "www.example",
        "http://www.w3.org/2011/http#requests": {
          "@list": [
            {
              "@type": "http://www.w3.org/2011/http#Request",
              "http://www.w3.org/2011/http#absolutePath": "/sparql/?default-graph-uri=http%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata0.rdf",
              "http://www.w3.org/2011/http#body": {
                "@type": "http://www.w3.org/2011/content#ContentAsText",
                "http://www.w3.org/2011/content#characterEncoding": "UTF-8",
                "http://www.w3.org/2011/content#chars": "query=ASK%20%7B%7D"
              },
              "http://www.w3.org/2011/http#headers": {
                "@list": [
                  {
                    "@type": "http://www.w3.org/2011/http#RequestHeader",
                    "http://www.w3.org/2011/http#fieldName": "content-type",
                    "http://www.w3.org/2011/http#fieldValue": "application/x-www-form-urlencoded"
                  }
                ]
              },
              "http://www.w3.org/2011/http#httpVersion": "1.1",
              "http://www.w3.org/2011/http#methodName": "POST",
              "http://www.w3.org/2011/http#resp": {
                "@type": "http://www.w3.org/2011/http#Response",
                "mf:expectedBoolean": {
                  "@type": "xsd:boolean",
                  "@value": "true"
                },
                "mf:expectedFormat": "boolean",
                "mf:expectedStatus": [
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode2xx"
                  },
                  {
                    "@id": "http://www.w3.org/2011/http#StatusCode3xx"
                  }
                ]
              }
            }
          ]
        }
      },
      "comment": "\n#### Request\n    \n    POST /sparql/?default-graph-uri=http%3A%2F%2Fkasei.us%2F2009%2F09%2Fsparql%2Fdata%2Fdata0.rdf HTTP/1.1\n    Host: www.example\n    Content-Type: application/x-www-form-urlencoded\n    Content-Length: 18\n    \n    query=ASK%20%7B%7D\n\n#### Response\n    \n    2xx or 3xx response\n    Content-Type: application/sparql-results+xml, application/sparql-results+json, or any other valid media type for boolean SPARQL results\n        \n    true\n        ",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-11-20#resolution_3"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/protocol/manifest#query_dataset_default_graphs_get",
