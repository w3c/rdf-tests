    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/subquery/manifest#subquery11",
      "@type": "mf:QueryEvaluationTest",
      "name": "sq11 - Subquery limit per resource",
      "comment": "This query limits results per number of orders, rather than by number of rows",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-01-31#resolution_3",
      "action": {
        "query": "sq11.rq",
        "data": "sq11.ttl"
      },
      "result": "sq11.srx"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/subquery/manifest#subquery12",
      "@type": "mf:QueryEvaluationTest",
      "name": "sq12 - Subquery in CONSTRUCT with built-ins",
      "comment": "This query constructs full names from first and last names",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-01-31#resolution_3",
      "action": {
        "query": "sq12.rq",
        "data": "sq12.ttl"
      },
      "result": "sq12_out.ttl"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/subquery/manifest#subquery13",
      "@type": "mf:QueryEvaluationTest",
      "name": "sq13 - Subqueries don't inject bindings",
      "comment": "The result of this subquery is a Kartesian product of all orders, rather than paris of orders sharing products, since subqueries are evaluated independent from bindings from outside the subquery",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-01-31#resolution_3",
      "action": {
        "query": "sq13.rq",
        "data": "sq13.ttl"
      },
      "result": "sq13.srx"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/subquery/manifest#subquery14",
      "@type": "mf:QueryEvaluationTest",
      "name": "sq14 - limit by resource",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-01-31#resolution_3",
      "action": {
        "query": "sq14.rq",
