      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/subquery/manifest#subquery10",
      "@type": "mf:QueryEvaluationTest",
      "name": "sq10 - Subquery with exists",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2010-07-20#resolution_2",
      "action": {
        "query": "sq10.rq",
