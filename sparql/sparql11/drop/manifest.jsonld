{
  "@context": {
    "@base": "https://w3c.github.io/rdf-tests/sparql/sparql11/drop/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "mf": "http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#",
    "mq": "http://www.w3.org/2001/sw/DataAccess/tests/test-query#",
    "rdft": "http://www.w3.org/ns/rdftest#",
    "dawgt": "http://www.w3.org/2001/sw/DataAccess/tests/test-dawg#",
    "ut": "http://www.w3.org/2009/sparql/tests/test-update#",
    "action": {
      "@id": "mf:action",
      "@type": "@id"
    },
    "comment": "rdfs:comment",
    "entries": {
      "@id": "mf:entries",
      "@container": "@list",
      "@type": "@id"
    },
    "include": {
      "@id": "mf:include",
      "@container": "@list",
      "@type": "@id"
    },
    "label": "rdfs:label",
    "name": "mf:name",
    "result": {
      "@id": "mf:result",
      "@type": "@id"
    },
    "entailmentRegime": {
      "@id": "mf:entailmentRegime"
    },
    "recognizedDatatypes": {
      "@id": "mf:recognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "unrecognizedDatatypes": {
      "@id": "mf:unrecognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "approval": {
      "@id": "dawgt:approval",
      "@type": "@id"
    },
    "approvedBy": {
      "@id": "dawgt:approvedBy",
      "@type": "@id"
    },
    "data": {
      "@id": "mq:data",
      "@type": "@id"
    },
    "feature": {
      "@id": "mf:feature",
      "@type": "@vocab"
    },
    "graphData": {
      "@id": "mq:graphData",
      "@type": "@id",
      "@container": "@set"
    },
    "notable": {
      "@id": "mf:notable",
      "@type": "@vocab"
    },
    "query": {
      "@id": "mq:query",
      "@type": "@id"
    },
    "queryForm": {
      "@id": "mq:queryForm",
      "@type": "@vocab"
    },
    "requires": {
      "@id": "mf:requires",
      "@type": "@vocab",
      "@container": "@set"
    },
    "ut:data": {
      "@id": "ut:data",
      "@type": "@id"
    },
    "ut:graphData": {
      "@id": "ut:graphData",
      "@container": "@set"
    },
    "ut:graph": {
      "@id": "ut:graph",
      "@type": "@id"
    },
    "ut:request": {
      "@id": "ut:request",
      "@type": "@id"
    }
  },
  "@id": "./",
  "@type": "mf:Manifest",
  "label": "DROP",
  "comment": "Tests for SPARQL UPDATE",
  "entries": [
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/drop/manifest#dawg-drop-default-01",
      "@type": "mf:UpdateEvaluationTest",
      "name": "DROP DEFAULT",
      "comment": "This is a DROP of the default graph",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_3",
      "action": {
        "ut:request": "drop-default-01.ru",
        "ut:data": "drop-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "drop-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "drop-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      },
      "result": {
        "ut:graphData": [
          {
            "ut:graph": "drop-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "drop-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/drop/manifest#dawg-drop-graph-01",
      "@type": "mf:UpdateEvaluationTest",
      "name": "DROP GRAPH",
      "comment": "This is a DROP of an existing named graph",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_3",
      "action": {
        "ut:request": "drop-graph-01.ru",
        "ut:data": "drop-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "drop-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "drop-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      },
      "result": {
        "ut:data": "drop-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "drop-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/drop/manifest#dawg-drop-named-01",
      "@type": "mf:UpdateEvaluationTest",
      "name": "DROP NAMED",
      "comment": "This is a DROP of all the named graphs",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_3",
      "action": {
        "ut:request": "drop-named-01.ru",
        "ut:data": "drop-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "drop-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "drop-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      },
      "result": {
        "ut:data": "drop-default.ttl"
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/drop/manifest#dawg-drop-all-01",
      "@type": "mf:UpdateEvaluationTest",
      "name": "DROP ALL",
      "comment": "This is a DROP of all graphs (default and named)",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_3",
      "action": {
        "ut:request": "drop-all-01.ru",
        "ut:data": "drop-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "drop-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "drop-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      },
      "result": {}
    }
  ]
}