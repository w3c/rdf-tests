  "@id": "./",
  "@type": "mf:Manifest",
  "label": "CSV/TSV Result Format",
  "entries": [
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/csv-tsv-res/manifest#csv01",
      "@type": "mf:CSVResultFormatTest",
      "name": "csv01 - CSV Result Format",
      "comment": "SELECT * WHERE { ?S ?P ?O }",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2011-08-16#resolution_3",
      "action": {
        "query": "csvtsv01.rq",
        "data": "data.ttl"
      },
      "result": "csvtsv01.csv"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/csv-tsv-res/manifest#tsv01",
      "@type": "mf:QueryEvaluationTest",
      "name": "tsv01 - TSV Result Format",
      "comment": "SELECT * WHERE { ?S ?P ?O }",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2011-08-16#resolution_3",
      "action": {
        "query": "csvtsv01.rq",
        "data": "data.ttl"
      },
      "result": "csvtsv01.tsv"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/csv-tsv-res/manifest#csv02",
      "@type": "mf:CSVResultFormatTest",
      "name": "cvs02 - CSV Result Format",
      "comment": "SELECT with OPTIONAL (i.e. not all vars bound in all results)",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2011-08-16#resolution_3",
      "action": {
        "query": "csvtsv02.rq",
        "data": "data.ttl"
      },
      "result": "csvtsv02.csv"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/csv-tsv-res/manifest#tsv02",
      "@type": "mf:QueryEvaluationTest",
      "name": "tsv02 - TSV Result Format",
      "comment": "SELECT with OPTIONAL (i.e. not all vars bound in all results)",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2011-08-16#resolution_3",
      "action": {
        "query": "csvtsv02.rq",
        "data": "data.ttl"
      },
      "result": "csvtsv02.tsv"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/csv-tsv-res/manifest#csv03",
      "@type": "mf:CSVResultFormatTest",
      "name": "csv03 - CSV Result Format",
      "comment": "SELECT * WHERE { ?S ?P ?O } with some corner cases of typed literals",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2011-08-16#resolution_3",
      "action": {
        "query": "csvtsv01.rq",
        "data": "data2.ttl"
      },
      "result": "csvtsv03.csv"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/csv-tsv-res/manifest#tsv03",
      "@type": "mf:QueryEvaluationTest",
      "name": "tsv03 - TSV Result Format",
      "comment": "SELECT * WHERE { ?S ?P ?O } with some corner cases of typed literals",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2011-08-16#resolution_3",
      "action": {
        "query": "csvtsv01.rq",
