      "@type": "mf:UpdateEvaluationTest",
      "name": "CLEAR NAMED",
      "comment": "This is a CLEAR of all the named graphs",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_3",
      "action": {
        "ut:request": "clear-named-01.ru",
        "ut:data": "clear-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "clear-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "clear-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      },
      "result": {
        "ut:data": "clear-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "empty.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "empty.ttl",
            "label": "http://example.org/g2"
