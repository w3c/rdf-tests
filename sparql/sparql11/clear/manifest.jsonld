  "@id": "./",
  "@type": "mf:Manifest",
  "label": "CLEAR",
  "comment": "Tests for SPARQL UPDATE",
  "entries": [
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/clear/manifest#dawg-clear-default-01",
      "@type": "mf:UpdateEvaluationTest",
      "name": "CLEAR DEFAULT",
      "comment": "This is a CLEAR of the default graph",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_3",
      "action": {
        "ut:request": "clear-default-01.ru",
        "ut:data": "clear-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "clear-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "clear-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      },
      "result": {
        "ut:data": "empty.ttl",
        "ut:graphData": [
          {
            "ut:graph": "clear-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "clear-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      }
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/clear/manifest#dawg-clear-graph-01",
      "@type": "mf:UpdateEvaluationTest",
      "name": "CLEAR GRAPH",
      "comment": "This is a CLEAR of an existing named graph",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_3",
      "action": {
        "ut:request": "clear-graph-01.ru",
        "ut:data": "clear-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "clear-g1.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "clear-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      },
      "result": {
        "ut:data": "clear-default.ttl",
        "ut:graphData": [
          {
            "ut:graph": "empty.ttl",
            "label": "http://example.org/g1"
          },
          {
            "ut:graph": "clear-g2.ttl",
            "label": "http://example.org/g2"
          }
        ]
      }
    },
    {
