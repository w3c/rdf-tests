{
  "@context": {
    "@base": "https://w3c.github.io/rdf-tests/sparql/sparql11/exists/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "mf": "http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#",
    "mq": "http://www.w3.org/2001/sw/DataAccess/tests/test-query#",
    "rdft": "http://www.w3.org/ns/rdftest#",
    "dawgt": "http://www.w3.org/2001/sw/DataAccess/tests/test-dawg#",
    "ut": "http://www.w3.org/2009/sparql/tests/test-update#",
    "action": {
      "@id": "mf:action",
      "@type": "@id"
    },
    "comment": "rdfs:comment",
    "entries": {
      "@id": "mf:entries",
      "@container": "@list",
      "@type": "@id"
    },
    "include": {
      "@id": "mf:include",
      "@container": "@list",
      "@type": "@id"
    },
    "label": "rdfs:label",
    "name": "mf:name",
    "result": {
      "@id": "mf:result",
      "@type": "@id"
    },
    "entailmentRegime": {
      "@id": "mf:entailmentRegime"
    },
    "recognizedDatatypes": {
      "@id": "mf:recognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "unrecognizedDatatypes": {
      "@id": "mf:unrecognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "approval": {
      "@id": "dawgt:approval",
      "@type": "@id"
    },
    "approvedBy": {
      "@id": "dawgt:approvedBy",
      "@type": "@id"
    },
    "data": {
      "@id": "mq:data",
      "@type": "@id"
    },
    "feature": {
      "@id": "mf:feature",
      "@type": "@vocab"
    },
    "graphData": {
      "@id": "mq:graphData",
      "@type": "@id",
      "@container": "@set"
    },
    "notable": {
      "@id": "mf:notable",
      "@type": "@vocab"
    },
    "query": {
      "@id": "mq:query",
      "@type": "@id"
    },
    "queryForm": {
      "@id": "mq:queryForm",
      "@type": "@vocab"
    },
    "requires": {
      "@id": "mf:requires",
      "@type": "@vocab",
      "@container": "@set"
    },
    "ut:data": {
      "@id": "ut:data",
      "@type": "@id"
    },
    "ut:graphData": {
      "@id": "ut:graphData",
      "@container": "@set"
    },
    "ut:graph": {
      "@id": "ut:graph",
      "@type": "@id"
    },
    "ut:request": {
      "@id": "ut:request",
      "@type": "@id"
    }
  },
  "@id": "./",
  "@type": "mf:Manifest",
  "label": "Positive Exists",
  "entries": [
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/exists/manifest#exists01",
      "@type": "mf:QueryEvaluationTest",
      "name": "Exists with one constant",
      "feature": "http://www.w3.org/ns/sparql#exists",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_2",
      "action": {
        "query": "exists01.rq",
        "data": "exists01.ttl"
      },
      "result": "exists01.srx"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/exists/manifest#exists02",
      "@type": "mf:QueryEvaluationTest",
      "name": "Exists with ground triple",
      "feature": "http://www.w3.org/ns/sparql#exists",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_2",
      "action": {
        "query": "exists02.rq",
        "data": "exists01.ttl"
      },
      "result": "exists02.srx"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/exists/manifest#exists03",
      "@type": "mf:QueryEvaluationTest",
      "name": "Exists within graph pattern",
      "feature": "http://www.w3.org/ns/sparql#exists",
      "comment": "Checks that exists is interpreted within named graph",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_2",
      "action": {
        "query": "exists03.rq",
        "data": "exists01.ttl",
        "graphData": [
          "exists02.ttl"
        ]
      },
      "result": "exists03.srx"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/exists/manifest#exists04",
      "@type": "mf:QueryEvaluationTest",
      "name": "Nested positive exists",
      "feature": "http://www.w3.org/ns/sparql#exists",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_2",
      "action": {
        "query": "exists04.rq",
        "data": "exists01.ttl"
      },
      "result": "exists04.srx"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/exists/manifest#exists05",
      "@type": "mf:QueryEvaluationTest",
      "name": "Nested negative exists in positive exists",
      "feature": "http://www.w3.org/ns/sparql#exists",
      "approval": "dawgt:Approved",
      "approvedBy": "http://www.w3.org/2009/sparql/meeting/2012-02-07#resolution_2",
      "action": {
        "query": "exists05.rq",
        "data": "exists01.ttl"
      },
      "result": "exists05.srx"
    },
    {
      "@id": "http://www.w3.org/2009/sparql/docs/tests/data-sparql11/exists/manifest#exists-graph-variable",
      "@type": "mf:QueryEvaluationTest",
      "name": "GRAPH variable inside of EXISTS is bound to external variable",
      "feature": "http://www.w3.org/ns/sparql#exists",
      "action": {
        "query": "exists-graph-variable.rq",
        "data": "exists-graph-variable.ttl",
        "graphData": [
          "exists-graph-variable.ttl"
        ]
      },
      "result": "exists-graph-variable.srx"
    }
  ]
}