{
  "@context": {
    "@base": "https://w3c.github.io/rdf-tests/sparql/sparql12/expression/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "mf": "http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#",
    "mq": "http://www.w3.org/2001/sw/DataAccess/tests/test-query#",
    "rdft": "http://www.w3.org/ns/rdftest#",
    "dawgt": "http://www.w3.org/2001/sw/DataAccess/tests/test-dawg#",
    "ut": "http://www.w3.org/2009/sparql/tests/test-update#",
    "action": {
      "@id": "mf:action",
      "@type": "@id"
    },
    "comment": "rdfs:comment",
    "entries": {
      "@id": "mf:entries",
      "@container": "@list",
      "@type": "@id"
    },
    "include": {
      "@id": "mf:include",
      "@container": "@list",
      "@type": "@id"
    },
    "label": "rdfs:label",
    "name": "mf:name",
    "result": {
      "@id": "mf:result",
      "@type": "@id"
    },
    "entailmentRegime": {
      "@id": "mf:entailmentRegime"
    },
    "recognizedDatatypes": {
      "@id": "mf:recognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "unrecognizedDatatypes": {
      "@id": "mf:unrecognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "approval": {
      "@id": "dawgt:approval",
      "@type": "@id"
    },
    "approvedBy": {
      "@id": "dawgt:approvedBy",
      "@type": "@id"
    },
    "data": {
      "@id": "mq:data",
      "@type": "@id"
    },
    "feature": {
      "@id": "mf:feature",
      "@type": "@vocab"
    },
    "graphData": {
      "@id": "mq:graphData",
      "@type": "@id",
      "@container": "@set"
    },
    "notable": {
      "@id": "mf:notable",
      "@type": "@vocab"
    },
    "query": {
      "@id": "mq:query",
      "@type": "@id"
    },
    "queryForm": {
      "@id": "mq:queryForm",
      "@type": "@vocab"
    },
    "requires": {
      "@id": "mf:requires",
      "@type": "@vocab",
      "@container": "@set"
    },
    "ut:data": {
      "@id": "ut:data",
      "@type": "@id"
    },
    "ut:graphData": {
      "@id": "ut:graphData",
      "@container": "@set"
    },
    "ut:graph": {
      "@id": "ut:graph",
      "@type": "@id"
    },
    "ut:request": {
      "@id": "ut:request",
      "@type": "@id"
    }
  },
  "@id": "./",
  "@type": "mf:Manifest",
  "label": "Expression",
  "entries": [
    {
      "@id": "manifest#not-not",
      "@type": "mf:QueryEvaluationTest",
      "name": "not-not",
      "comment": "Double negation !!",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "not-not.rq"
      },
      "result": "not-not.srx"
    },
    {
      "@id": "manifest#triple-on-literals",
      "@type": "mf:QueryEvaluationTest",
      "name": "triple on literals",
      "comment": "Evaluation of TRIPLE builtin on literals",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "triple-on-literals.rq"
      },
      "result": "triple-on-literals.srj"
    },
    {
      "@id": "manifest#triple-on-str-literals",
      "@type": "mf:QueryEvaluationTest",
      "name": "triple on string literals",
      "comment": "Evaluation of TRIPLE builtin on string literals",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "triple-on-str-literals.rq"
      },
      "result": "triple-on-str-literals.srj"
    },
    {
      "@id": "manifest#triple-on-triple-terms",
      "@type": "mf:QueryEvaluationTest",
      "name": "triple on triple terms",
      "comment": "Evaluation of TRIPLE builtin on triple terms",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "triple-on-triple-terms.rq"
      },
      "result": "triple-on-triple-terms.srj"
    },
    {
      "@id": "manifest#triple-on-undefs",
      "@type": "mf:QueryEvaluationTest",
      "name": "triple on undefs",
      "comment": "Evaluation of TRIPLE builtin on UNDEFs",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "triple-on-undefs.rq"
      },
      "result": "triple-on-undefs.srj"
    }
  ]
}