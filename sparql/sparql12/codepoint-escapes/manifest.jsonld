  "@id": "./",
  "@type": "mf:Manifest",
  "label": "SPARQL Codepoint-Escaping Tests",
  "entries": [
    {
      "@id": "manifest#codepoint-esc-01",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-01.rq",
      "action": "codepoint-esc-01.rq"
    },
    {
      "@id": "manifest#codepoint-esc-02",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-02.rq",
      "comment": "codepoint escape for the backslash of a PN_LOCAL_ESC in the PN_LOCAL part of a PrefixedName",
      "action": "codepoint-esc-02.rq"
    },
    {
      "@id": "manifest#codepoint-esc-bad-03",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-bad-03.rq",
      "comment": "codepoint escape that results in an invalid backslash escape (requires handling codepoint escaping before backslash escaping)",
      "action": "codepoint-esc-bad-03.rq"
    },
    {
      "@id": "manifest#codepoint-esc-04",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-04.rq",
      "comment": "codepoint escape that results in a valid backslash escape",
      "action": "codepoint-esc-04.rq"
    },
    {
      "@id": "manifest#codepoint-esc-05",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-05.rq",
      "action": "codepoint-esc-05.rq"
    },
    {
      "@id": "manifest#codepoint-esc-06",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-06.rq",
      "comment": "codepoint escape for the percent sign in the PL_LOCAL part of a PrefixedName",
      "action": "codepoint-esc-06.rq"
    },
    {
      "@id": "manifest#codepoint-esc-07",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-07.rq",
      "comment": "codepoint escape for whitespace separating the projection tokens: SELECT * WHERE",
      "action": "codepoint-esc-07.rq"
    },
    {
      "@id": "manifest#codepoint-esc-08",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-08.rq",
      "comment": "codepoint escape for the starting double-quote of a literal",
      "action": "codepoint-esc-08.rq"
    }
  ]
}