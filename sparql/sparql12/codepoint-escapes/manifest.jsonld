  "@type": "mf:Manifest",
  "label": "SPARQL Codepoint-Escaping Tests",
  "entries": [
    {
      "@id": "manifest#codepoint-esc-01-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-01-bad.rq",
      "comment": "Whole query in codepoint escapes",
      "action": "codepoint-esc-01-bad.rq"
    },
    {
      "@id": "manifest#codepoint-esc-02-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-02-bad.rq",
      "comment": "Codepoint escape in PNAME_NS of a prefixed name",
      "action": "codepoint-esc-02-bad.rq"
    },
    {
      "@id": "manifest#codepoint-esc-03-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-03-bad.rq",
      "comment": "Codepoint escape in PN_LOCAL of a prefixed name",
      "action": "codepoint-esc-03-bad.rq"
    },
    {
      "@id": "manifest#codepoint-esc-04-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-04-bad.rq",
      "comment": "Codepoint escape in variable",
      "action": "codepoint-esc-04-bad.rq"
    },
    {
      "@id": "manifest#codepoint-esc-05",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-05.rq",
      "comment": "Codepoint escape in IRI",
      "action": "codepoint-esc-05.rq"
    },
    {
      "@id": "manifest#codepoint-esc-06",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-06.rq",
      "comment": "Codepoint escape in string - double quoted string",
      "action": "codepoint-esc-06.rq"
    },
    {
      "@id": "manifest#codepoint-esc-07",
      "@type": "mf:PositiveSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "codepoint-esc-07.rq",
      "comment": "Codepoint escape in string - single quoted string",
      "action": "codepoint-esc-07.rq"
    },
    {
      "@id": "manifest#surrogate-esc-01-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "surrogate-esc-01-bad.rq",
      "comment": "Surrogate pair - not accepted",
      "action": "surrogate-esc-01-bad.rq"
    },
    {
      "@id": "manifest#surrogate-esc-02-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "surrogate-esc-02-bad.rq",
      "comment": "Surrogate - low-high - not accepted",
      "action": "surrogate-esc-02-bad.rq"
    },
    {
      "@id": "manifest#surrogate-esc-03-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "surrogate-esc-03-bad.rq",
      "comment": "Surrogate - lone high escape sequence",
      "action": "surrogate-esc-03-bad.rq"
    },
    {
      "@id": "manifest#surrogate-esc-04-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
      "name": "surrogate-esc-04-bad.rq",
      "comment": "Surrogate - lone low escape sequence",
      "action": "surrogate-esc-04-bad.rq"
    },
    {
      "@id": "manifest#surrogate-esc-05-bad",
      "@type": "mf:NegativeSyntaxTest",
      "approval": "dawgt:Proposed",
