{
  "@context": {
    "@base": "https://w3c.github.io/rdf-tests/sparql/sparql12/rdf11/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "mf": "http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#",
    "mq": "http://www.w3.org/2001/sw/DataAccess/tests/test-query#",
    "rdft": "http://www.w3.org/ns/rdftest#",
    "dawgt": "http://www.w3.org/2001/sw/DataAccess/tests/test-dawg#",
    "ut": "http://www.w3.org/2009/sparql/tests/test-update#",
    "action": {
      "@id": "mf:action",
      "@type": "@id"
    },
    "comment": "rdfs:comment",
    "entries": {
      "@id": "mf:entries",
      "@container": "@list",
      "@type": "@id"
    },
    "include": {
      "@id": "mf:include",
      "@container": "@list",
      "@type": "@id"
    },
    "label": "rdfs:label",
    "name": "mf:name",
    "result": {
      "@id": "mf:result",
      "@type": "@id"
    },
    "entailmentRegime": {
      "@id": "mf:entailmentRegime"
    },
    "recognizedDatatypes": {
      "@id": "mf:recognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "unrecognizedDatatypes": {
      "@id": "mf:unrecognizedDatatypes",
      "@type": "@id",
      "@container": "@list"
    },
    "approval": {
      "@id": "dawgt:approval",
      "@type": "@id"
    },
    "approvedBy": {
      "@id": "dawgt:approvedBy",
      "@type": "@id"
    },
    "data": {
      "@id": "mq:data",
      "@type": "@id"
    },
    "feature": {
      "@id": "mf:feature",
      "@type": "@vocab"
    },
    "graphData": {
      "@id": "mq:graphData",
      "@type": "@id",
      "@container": "@set"
    },
    "notable": {
      "@id": "mf:notable",
      "@type": "@vocab"
    },
    "query": {
      "@id": "mq:query",
      "@type": "@id"
    },
    "queryForm": {
      "@id": "mq:queryForm",
      "@type": "@vocab"
    },
    "requires": {
      "@id": "mf:requires",
      "@type": "@vocab",
      "@container": "@set"
    },
    "ut:data": {
      "@id": "ut:data",
      "@type": "@id"
    },
    "ut:graphData": {
      "@id": "ut:graphData",
      "@container": "@set"
    },
    "ut:graph": {
      "@id": "ut:graph",
      "@type": "@id"
    },
    "ut:request": {
      "@id": "ut:request",
      "@type": "@id"
    }
  },
  "@id": "./",
  "@type": "mf:Manifest",
  "label": "RDF 1.1 literals handling",
  "entries": [
    {
      "@id": "manifest#langstring-datatype",
      "@type": "mf:QueryEvaluationTest",
      "name": "DATATYPE on rdf:langString",
      "comment": "plain literals with a language tag have a rdf:langString datatype",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "langstring-datatype.rq"
      },
      "result": "langstring-datatype.srj"
    },
    {
      "@id": "manifest#plain-string-datatype",
      "@type": "mf:QueryEvaluationTest",
      "name": "DATATYPE on plain string literal",
      "comment": "plain literals without a language tag have the xsd:string datatype",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "plain-string-datatype.rq"
      },
      "result": "plain-string-datatype.srj"
    },
    {
      "@id": "manifest#plain-string-same",
      "@type": "mf:QueryEvaluationTest",
      "name": "xsd:string and plain literals are the same",
      "comment": "xsd:string literals are the same as literals without datatypes",
      "approval": "dawgt:Proposed",
      "action": {
        "query": "plain-string-same.rq"
      },
      "result": "plain-string-same.srj"
    }
  ]
}